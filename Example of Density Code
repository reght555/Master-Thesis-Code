def plane_area(plane): # takes cross product of coplanar atoms
    x = plane[:,0]
    y = plane[:,1]
    return (x.max() - x.min()) * (y.max() - y.min())

def plane_density(plane): #literally function to divide number of atoms by area
    x=len(plane)
    rho=len(plane)/plane_area(plane)
    return rho

