import numpy as np
import matplotlib.pyplot as plt

data_dict = {}
txt = '3x3.txt' # Example file change when using.
# Same dictionary used to read file within STM model.
with open(txt, 'r') as file:
    for line in file:
        parts = line.strip().split()
        
        #extracts coordinates and creates a dictionary key
        key = parts[0]
        coordinates = np.round((float(parts[1]), float(parts[2]), float(parts[3])),3) 
      
        if key in data_dict:
            data_dict[key].append(coordinates)
        else:
            data_dict[key] = [coordinates]

pts = np.vstack(list(data_dict.values())) # a giant dictionary of atomic coordinates from file

yb_coords = np.vstack(data_dict["In"])
yb_coords = np.vstack(data_dict["In"])

def planes_finder(eps=0.35): #function to search through dictionary of coords and find yb planes, eps is a parameter used to cut off atoms and seperate planes
    yb = np.vstack(data_dict["In"])

    mask = (yb[:,2] >= 46.5) & (yb[:,2] <= 73)
    yb = yb[mask]
    yb = yb[np.argsort(yb[:,2])]
    planes = []
    current_plane = [yb[0]]

    for i in range(1, len(yb)):
        if abs(yb[i,2] - np.mean([p[2] for p in current_plane])) <= eps:
            current_plane.append(yb[i])
        else:
            planes.append(np.array(current_plane))
            current_plane = [yb[i]]

    planes.append(np.array(current_plane))

    return planes

